generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Utilisateurs admin ──────────────────────────────────────
model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String
  role      Role     @default(ADMIN)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

enum Role {
  ADMIN
  SUPER_ADMIN
}

// ── Catégories ──────────────────────────────────────────────
model Category {
  id          String     @id @default(uuid())
  name        String
  nameEn      String?
  slug        String     @unique
  description String?
  image       String?
  parentId    String?
  parent      Category?  @relation("SubCategories", fields: [parentId], references: [id])
  children    Category[] @relation("SubCategories")
  products    Product[]
  isActive    Boolean    @default(true)
  sortOrder   Int        @default(0)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@map("categories")
}

// ── Fournisseurs (AliExpress) ────────────────────────────────
model Supplier {
  id          String    @id @default(uuid())
  name        String    @default("AliExpress")
  website     String?
  apiKey      String?
  isActive    Boolean   @default(true)
  products    Product[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("suppliers")
}

// ── Produits ────────────────────────────────────────────────
model Product {
  id              String           @id @default(uuid())
  name            String
  nameEn          String?
  slug            String           @unique
  description     String?          @db.Text
  descriptionEn   String?          @db.Text
  shortDesc       String?
  price           Decimal          @db.Decimal(10, 2)
  comparePrice    Decimal?         @db.Decimal(10, 2)
  costPrice       Decimal?         @db.Decimal(10, 2)
  currency        String           @default("XOF")
  stock           Int              @default(0)
  sku             String?          @unique
  weight          Decimal?         @db.Decimal(8, 2)
  isActive        Boolean          @default(true)
  isFeatured      Boolean          @default(false)
  metaTitle       String?
  metaDescription String?
  tags            String[]

  // AliExpress source
  aliexpressUrl   String?
  aliexpressId    String?
  lastSyncAt      DateTime?

  // Relations
  categoryId      String?
  category        Category?        @relation(fields: [categoryId], references: [id])
  supplierId      String?
  supplier        Supplier?        @relation(fields: [supplierId], references: [id])
  images          ProductImage[]
  variants        ProductVariant[]
  orderItems      OrderItem[]
  reviews         Review[]

  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@map("products")
}

// ── Images produits ─────────────────────────────────────────
model ProductImage {
  id        String   @id @default(uuid())
  url       String
  alt       String?
  sortOrder Int      @default(0)
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@map("product_images")
}

// ── Variantes produits ───────────────────────────────────────
model ProductVariant {
  id         String      @id @default(uuid())
  name       String      // ex: "Taille M - Rouge"
  sku        String?
  price      Decimal     @db.Decimal(10, 2)
  stock      Int         @default(0)
  image      String?
  attributes Json        // ex: {"taille": "M", "couleur": "Rouge"}
  productId  String
  product    Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  orderItems OrderItem[]
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  @@map("product_variants")
}

// ── Clients ─────────────────────────────────────────────────
model Customer {
  id          String    @id @default(uuid())
  email       String    @unique
  password    String?
  firstName   String
  lastName    String
  phone       String?
  country     String?
  city        String?
  address     String?
  isActive    Boolean   @default(true)
  orders      Order[]
  reviews     Review[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("customers")
}

// ── Commandes ───────────────────────────────────────────────
model Order {
  id              String        @id @default(uuid())
  orderNumber     String        @unique
  status          OrderStatus   @default(PENDING)

  // Client
  customerId      String?
  customer        Customer?     @relation(fields: [customerId], references: [id])
  customerName    String
  customerEmail   String
  customerPhone   String

  // Livraison
  shippingAddress String
  shippingCity    String
  shippingCountry String
  shippingMethod  String?

  // Montants
  subtotal        Decimal       @db.Decimal(10, 2)
  shippingCost    Decimal       @default(0) @db.Decimal(10, 2)
  discount        Decimal       @default(0) @db.Decimal(10, 2)
  total           Decimal       @db.Decimal(10, 2)
  currency        String        @default("XOF")

  // AliExpress
  aliexpressOrderId String?
  supplierOrderStatus String?

  // Relations
  items           OrderItem[]
  payment         Payment?
  tracking        Tracking?
  couponId        String?
  coupon          Coupon?       @relation(fields: [couponId], references: [id])
  notes           String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@map("orders")
}

enum OrderStatus {
  PENDING
  PAYMENT_PENDING
  PAID
  PROCESSING
  ORDERED_FROM_SUPPLIER
  SHIPPED
  DELIVERED
  CANCELLED
  REFUNDED
}

// ── Articles de commande ─────────────────────────────────────
model OrderItem {
  id          String          @id @default(uuid())
  quantity    Int
  price       Decimal         @db.Decimal(10, 2)
  total       Decimal         @db.Decimal(10, 2)
  productName String
  variantName String?
  orderId     String
  order       Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId   String?
  product     Product?        @relation(fields: [productId], references: [id])
  variantId   String?
  variant     ProductVariant? @relation(fields: [variantId], references: [id])
  createdAt   DateTime        @default(now())

  @@map("order_items")
}

// ── Paiements ────────────────────────────────────────────────
model Payment {
  id              String        @id @default(uuid())
  orderId         String        @unique
  order           Order         @relation(fields: [orderId], references: [id])
  amount          Decimal       @db.Decimal(10, 2)
  currency        String        @default("XOF")
  method          PaymentMethod
  status          PaymentStatus @default(PENDING)
  transactionId   String?       // ID FedaPay
  phoneNumber     String?       // Numéro mobile money
  operator        String?       // MTN, MOOV, ORANGE, WAVE
  country         String?
  gatewayData     Json?         // Réponse complète FedaPay
  paidAt          DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@map("payments")
}

enum PaymentMethod {
  MTN_MOMO
  MOOV_MONEY
  ORANGE_MONEY
  WAVE
  FEDAPAY
  CARD
}

enum PaymentStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  CANCELLED
  REFUNDED
}

// ── Suivi colis ──────────────────────────────────────────────
model Tracking {
  id             String    @id @default(uuid())
  orderId        String    @unique
  order          Order     @relation(fields: [orderId], references: [id])
  trackingNumber String?
  carrier        String?
  status         String    @default("PENDING")
  events         Json[]    @default([])
  estimatedDate  DateTime?
  deliveredAt    DateTime?
  lastCheckedAt  DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@map("tracking")
}

// ── Avis clients ─────────────────────────────────────────────
model Review {
  id         String   @id @default(uuid())
  rating     Int      // 1-5
  title      String?
  comment    String?  @db.Text
  isVerified Boolean  @default(false)
  isApproved Boolean  @default(false)
  productId  String
  product    Product  @relation(fields: [productId], references: [id])
  customerId String?
  customer   Customer? @relation(fields: [customerId], references: [id])
  createdAt  DateTime @default(now())

  @@map("reviews")
}

// ── Coupons ──────────────────────────────────────────────────
model Coupon {
  id            String       @id @default(uuid())
  code          String       @unique
  type          CouponType
  value         Decimal      @db.Decimal(10, 2)
  minOrder      Decimal?     @db.Decimal(10, 2)
  usageLimit    Int?
  usageCount    Int          @default(0)
  isActive      Boolean      @default(true)
  expiresAt     DateTime?
  orders        Order[]
  createdAt     DateTime     @default(now())

  @@map("coupons")
}

enum CouponType {
  PERCENTAGE
  FIXED
}

// ── Notifications ────────────────────────────────────────────
model Notification {
  id        String           @id @default(uuid())
  type      NotificationType
  title     String
  message   String           @db.Text
  data      Json?
  isRead    Boolean          @default(false)
  userId    String?
  createdAt DateTime         @default(now())

  @@map("notifications")
}

enum NotificationType {
  ORDER_NEW
  ORDER_PAID
  ORDER_SHIPPED
  ORDER_DELIVERED
  STOCK_LOW
  PRICE_CHANGE
  SYSTEM
}

// ── Analytics ────────────────────────────────────────────────
model Analytics {
  id        String   @id @default(uuid())
  event     String
  data      Json
  ip        String?
  userAgent String?
  country   String?
  createdAt DateTime @default(now())

  @@map("analytics")
}

// ── Resi Group — Contenu du site ─────────────────────────────
model ResiContent {
  id        String   @id @default(uuid())
  key       String   @unique  // 'immo' | 'vols' | 'cars' | 'liv' | 'restos' | 'svcs' | 'streaming' | 'settings'
  data      Json
  updatedAt DateTime @updatedAt

  @@map("resi_content")
}

// ── Resi Group — Demandes clients ───────────────────────────
model ResiRequest {
  id        String            @id @default(uuid())
  type      ResiRequestType
  name      String
  phone     String
  email     String?
  subject   String?           // service demandé (ex: "Netflix Standard")
  message   String?
  status    ResiRequestStatus @default(NEW)
  data            Json?             // champs supplémentaires
  resiCustomerId  String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@map("resi_requests")
}

enum ResiRequestType {
  STREAMING
  IMMOBILIER
  VOLS
  VOITURES
  LIVRAISON
  RESTAURATION
  SERVICES
  CONTACT
}

enum ResiRequestStatus {
  NEW
  IN_PROGRESS
  DONE
  CANCELLED
}

// ── Resi Group — Admin credentials ──────────────────────────
model ResiAdmin {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  name         String   @default("Admin")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("resi_admin")
}

// ── Resi Group — Clients ─────────────────────────────────────
model ResiCustomer {
  id           String        @id @default(uuid())
  email        String        @unique
  passwordHash String
  name         String
  phone        String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  @@map("resi_customers")
}

model ResiAiUnanswered {
  id        String   @id @default(uuid())
  question  String
  count     Int      @default(1)
  lastAsked DateTime @default(now())
  createdAt DateTime @default(now())
  @@map("resi_ai_unanswered")
}

model ResiAiKnowledge {
  id        String   @id @default(uuid())
  keywords  String   // mots-clés séparés par virgule, utilisés pour reconnaître la question
  answer    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@map("resi_ai_knowledge")
}

// ── Le Bon Samaritain — Contenu du site (back-office) ────────
model LbsContent {
  id        String   @id @default(uuid())
  key       String   @unique // 'categories' | 'products' | 'gallery' | 'testimonials' | 'blog' | 'settings'
  data      Json
  updatedAt DateTime @updatedAt

  @@map("lbs_content")
}

// ── Le Bon Samaritain — Admin credentials ─────────────────────
model LbsAdmin {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  name         String   @default("Admin")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("lbs_admin")
}
